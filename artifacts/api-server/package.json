  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@types/multer": "^2.1.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
